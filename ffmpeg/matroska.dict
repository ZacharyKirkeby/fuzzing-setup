channels="\x9f"
bit_depth="\x62\x64"

# -----------------------------------------------------------------------------
# Codec IDs — string tokens AFL++ can splice into codec_id element bodies
# -----------------------------------------------------------------------------
codec_v_vp8="V_VP8"
codec_v_vp9="V_VP9"
codec_v_av1="V_AV1"
