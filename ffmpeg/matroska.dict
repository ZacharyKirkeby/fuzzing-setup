# =============================================================================
# Matroska / WebM / EBML AFL++ Fuzzing Dictionary
# Based on the EBML spec and Matroska spec (IETF RFC 9559)
# Each token is a raw byte sequence AFL++ will splice into mutations.
# =============================================================================

# -----------------------------------------------------------------------------
# EBML Header magic — must appear at offset 0 of every valid file.
# Without this, almost every mutation fails the very first header check.
# -----------------------------------------------------------------------------
ebml_magic="\x1a\x45\xdf\xa3"

# -----------------------------------------------------------------------------
# EBML Header elements
# -----------------------------------------------------------------------------
ebml_version="\x42\x86"
ebml_read_version="\x42\xf7"
ebml_max_id_length="\x42\xf2"
ebml_max_size_length="\x42\xf3"
ebml_doc_type="\x42\x82"
ebml_doc_type_version="\x42\x87"
ebml_doc_type_read_version="\x42\x85"

# -----------------------------------------------------------------------------
# DocType strings — UTF-8, inserted as token values
# -----------------------------------------------------------------------------
doctype_matroska="matroska"
doctype_webm="webm"

# -----------------------------------------------------------------------------
# EBML variable-length integer (vint) size markers
# These appear before every element body and are frequently worth targeting.
# -----------------------------------------------------------------------------
vint_1byte="\x80"
vint_2byte="\x40\x00"
vint_4byte="\x20\x00\x00\x00"
vint_8byte="\x01\x00\x00\x00\x00\x00\x00\x00"
vint_unknown_size="\x01\xff\xff\xff\xff\xff\xff\xff"

# -----------------------------------------------------------------------------
# Segment
# -----------------------------------------------------------------------------
segment="\x18\x53\x80\x67"
seek_head="\x11\x4d\x9b\x74"
seek="\x4d\xbb"
seek_id="\x53\xab"
seek_position="\x53\xac"

# -----------------------------------------------------------------------------
# Segment Info
# -----------------------------------------------------------------------------
info="\x15\x49\xa9\x66"
segment_uid="\x73\xa4"
segment_filename="\x73\x84"
prev_uid="\x3c\xb9\x23"
prev_filename="\x3c\x83\xab"
next_uid="\x3e\xb9\x23"
next_filename="\x3e\x83\xbb"
timecode_scale="\x2a\xd7\xb1"
duration="\x44\x89"
date_utc="\x44\x61"
title="\x7b\xa9"
muxing_app="\x4d\x80"
writing_app="\x57\x41"

# -----------------------------------------------------------------------------
# Cluster
# -----------------------------------------------------------------------------
cluster="\x1f\x43\xb6\x75"
timestamp="\xe7"
silent_tracks="\x58\x54"
silent_track_number="\x58\xd7"
position="\xa7"
prev_size="\xab"
simple_block="\xa3"
block_group="\xa0"
block="\xa1"
block_virtual="\xa2"
block_additions="\x75\xa1"
block_more="\xa6"
block_add_id="\xee"
block_additional="\xa5"
block_duration="\x9b"
reference_priority="\xfa"
reference_block="\xfb"
reference_virtual="\xfd"
codec_state="\xa4"
discard_padding="\x75\xa2"
slices="\x8e"
time_slice="\xe8"
lace_number="\xcc"

# -----------------------------------------------------------------------------
# Block flags (single byte, various lacing/keyframe combinations)
# -----------------------------------------------------------------------------
block_flag_keyframe="\x80"
block_flag_invisible="\x08"
block_flag_lacing_xiph="\x02"
block_flag_lacing_fixed="\x04"
block_flag_lacing_ebml="\x06"
block_flag_discardable="\x01"

# -----------------------------------------------------------------------------
# Tracks
# -----------------------------------------------------------------------------
tracks="\x16\x54\xae\x6b"
track_entry="\xae"
track_number="\xd7"
track_uid="\x73\xc5"
track_type="\x83"
